<Application
    x:Class="TB.Core.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Explicit WinUI generic theme merge (avoids XamlControlsResources validation bug in CI) -->
                <ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/Themes/generic.xaml" />
                <ResourceDictionary Source="ms-appx:///UI/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
