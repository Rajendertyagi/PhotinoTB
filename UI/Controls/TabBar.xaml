<UserControl x:Class="TB_Browser.UI.Controls.TabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Scrollable Tabs -->
        <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="TabsPanel" Orientation="Horizontal" Margin="10,0,0,0"/>
        </ScrollViewer>

        <!-- Window Controls -->
        <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button Style="{StaticResource IconBtn}" Content="─" Click="Minimize_Click"/>
            <Button Style="{StaticResource IconBtn}" Content="□" Click="Maximize_Click"/>
            <Button Style="{StaticResource IconBtn}" Content="✕" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
