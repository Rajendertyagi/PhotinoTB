<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid Margin="8,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Content="←" Width="32" Height="32" Background="Transparent"
                Foreground="White" BorderThickness="0" FontSize="14" Click="Back_Click"/>
        <Button Grid.Column="1" Content="→" Width="32" Height="32" Background="Transparent"
                Foreground="White" BorderThickness="0" FontSize="14" Click="Forward_Click"/>

        <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="4"
                Padding="12,6" Margin="8,0">
            <TextBox x:Name="UrlBox" Background="Transparent" Foreground="White"
                     BorderThickness="0" VerticalAlignment="Center" KeyDown="Url_KeyDown"/>
        </Border>

        <Button Grid.Column="3" Content="Go" Width="60" Height="32" Background="{StaticResource AccentBrush}"
                Foreground="Black" BorderThickness="0" FontWeight="SemiBold" Click="Go_Click"/>
    </Grid>
</UserControl>
