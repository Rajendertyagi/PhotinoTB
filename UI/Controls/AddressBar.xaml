<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <Button Grid.Column="0" x:Name="BackBtn" Content="←" Style="{StaticResource NavBtn}" Click="Back_Click" Margin="0,0,4,0" IsEnabled="False"/>
        <Button Grid.Column="1" x:Name="FwdBtn" Content="→" Style="{StaticResource NavBtn}" Click="Forward_Click" Margin="0,0,4,0" IsEnabled="False"/>
        <Button Grid.Column="2" x:Name="ReloadBtn" Content="⟳" Style="{StaticResource NavBtn}" Click="Reload_Click" Margin="0,0,4,0"/>
        <Border Grid.Column="3" Background="#303134" CornerRadius="18" Padding="8,4" Margin="0,2">
            <TextBox x:Name="UrlBox" Background="Transparent" Foreground="#fff" BorderThickness="0" VerticalAlignment="Center" KeyDown="Url_KeyDown" TextChanged="Url_TextChanged"/>
        </Border>
        <Button Grid.Column="4" Content="Go" Background="#1a73e8" Foreground="#fff" BorderThickness="0" Padding="16,6" Margin="8,0,0,0" Click="Go_Click">
            <Button.Template><ControlTemplate TargetType="{x:Type Button}"><Border Background="{TemplateBinding Background}" CornerRadius="18"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
        </Button>
    </Grid>
</UserControl>
