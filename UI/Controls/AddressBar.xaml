<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ColumnSpacing="8" Padding="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="←" Style="{StaticResource NavBtn}" Click="Back_Click"/>
        <Button Grid.Column="1" Content="→" Style="{StaticResource NavBtn}" Click="Forward_Click"/>
        <Button Grid.Column="2" Content="⟳" Style="{StaticResource NavBtn}" Click="Reload_Click"/>
        <TextBox Grid.Column="3" x:Name="UrlBox" PlaceholderText="Search or enter URL" KeyDown="Url_KeyDown"/>
        <Button Grid.Column="4" Content="Go" Padding="16,6" CornerRadius="18" Click="Go_Click"/>
    </Grid>
</UserControl>
