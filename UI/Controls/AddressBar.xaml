<UserControl x:Class="TB_Browser.UI.Controls.AddressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}" Padding="0,6">
    <Grid Margin="10,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Nav Buttons -->
        <StackPanel Grid.Column="0" Orientation="Horizontal">
            <Button Style="{StaticResource IconBtn}" Content="←" Click="Back_Click"/>
            <Button Style="{StaticResource IconBtn}" Content="→" Click="Forward_Click"/>
            <Button Style="{StaticResource IconBtn}" Content="" Click="Reload_Click"/>
        </StackPanel>

        <!-- URL Pill -->
        <Border Grid.Column="1" Background="#181818" CornerRadius="20" Padding="12,6" Margin="8,0">
            <TextBox x:Name="UrlBox" Background="Transparent" Foreground="White"
                     BorderThickness="0" VerticalAlignment="Center" FontSize="14"
                     KeyDown="Url_KeyDown"/>
        </Border>
    </Grid>
</UserControl>
