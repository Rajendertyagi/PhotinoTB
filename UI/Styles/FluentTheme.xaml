<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Fluent Dark Colors -->
    <Color x:Key="FluentBackground">#202020</Color>
    <Color x:Key="FluentSurface">#2C2C2C</Color>
    <Color x:Key="FluentSurfaceBright">#3A3A3A</Color>
    <Color x:Key="FluentText">#FFFFFF</Color>
    <Color x:Key="FluentTextDisabled">#A0A0A0</Color>
    <Color x:Key="FluentAccent">#60CDFF</Color>
    <Color x:Key="FluentHover">#3F3F3F</Color>

    <SolidColorBrush x:Key="FluentBackgroundBrush" Color="{StaticResource FluentBackground}"/>
    <SolidColorBrush x:Key="FluentSurfaceBrush" Color="{StaticResource FluentSurface}"/>
    <SolidColorBrush x:Key="FluentTextBrush" Color="{StaticResource FluentText}"/>
    <SolidColorBrush x:Key="FluentAccentBrush" Color="{StaticResource FluentAccent}"/>

    <!-- Modern Button Style -->
    <Style x:Key="FluentButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource FluentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource FluentSurfaceBright}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tab Button Style -->
    <Style x:Key="FluentTab" TargetType="Button">
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="MaxWidth" Value="240"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4 4 0 0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
