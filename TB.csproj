<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    
    <!-- 1. Disable MSIX packaging -->
    <WindowsPackageType>None</WindowsPackageType>
    <EnableMsixTooling>false</EnableMsixTooling>
    <GenerateAppxPackageOnBuild>false</GenerateAppxPackageOnBuild>
    <MrtCoreResourceIndexerSkipGeneration>true</MrtCoreResourceIndexerSkipGeneration>
    
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    
    <!-- 2. Ensure .NET 8 compatibility on runner -->
    <UseWindowsSdkDesktopFrameworkOnly>true</UseWindowsSdkDesktopFrameworkOnly>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.6.240923002" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.1742" />
  </ItemGroup>

  <!-- 3. OVERRIDE THE BROKEN TARGET -->
  <!-- This replaces the MSBuild task that is looking for the missing DLL -->
  <Target Name="ExpandPriContent" />

</Project>
